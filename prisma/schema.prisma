// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())

  sessions     Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeighIn {
  id            String   @id @default(cuid())
  measuredAt    DateTime
  weightKg      Float
  bodyFatPct    Float?
  muscleMassKg  Float?
  sourceFile    String?
  rawText       String?
  metricsJson   String?  // JSON blob of all extracted Evolt metrics
  createdAt     DateTime @default(now())

  @@index([measuredAt])
}
